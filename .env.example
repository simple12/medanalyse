# FHIR Server (local dev — use http://localhost:8082/fhir)
# Docker Compose sets FHIR_CONFIG_PATH=/app/config/fhir.json for runtime switching
FHIR_BASE_URL=http://localhost:8082/fhir
FHIR_ACCESS_TOKEN=

# Optional display label for the FHIR data source shown in the UI (e.g. Medblocks, Epic, Public HAPI Sandbox)
# FHIR_SOURCE_LABEL=Local HAPI

# Multi-source registry (optional JSON array). When unset, defaults are built from the vars below.
# FHIR_SOURCES_JSON=[{"id":"hapi","label":"HAPI","subtitle":"Public sandbox","baseUrl":"https://hapi.fhir.org/baseR4","authType":"none"}]

# Per-source overrides (used when FHIR_SOURCES_JSON is not set)
HAPI_FHIR_BASE_URL=https://hapi.fhir.org/baseR4
# MEDBLOCKS_FHIR_BASE_URL=
# MEDBLOCKS_FHIR_ACCESS_TOKEN=

# Cerner SMART (optional — enables Cerner in the source selector)
# CERNER_CLIENT_ID=
# CERNER_CLIENT_SECRET=
# CERNER_ISSUER=https://fhir-ehr-code.cerner.com/r4/ec2458f2-1e24-41c8-b71b-0e701af7583d
# CERNER_FHIR_BASE_URL=
# CERNER_SCOPES=openid fhirUser launch/patient patient/*.read patient/*.write user/*.read offline_access

# Epic SMART (optional — enables Epic in the source selector)
# EPIC_CLIENT_ID=
# EPIC_CLIENT_SECRET=
# EPIC_ISSUER=https://fhir.epic.com/interconnect-fhir-oauth/api/FHIR/R4
# EPIC_FHIR_BASE_URL=
# EPIC_SCOPES=openid fhirUser launch/patient patient/Patient.read patient/Observation.read patient/Condition.read patient/MedicationRequest.read offline_access

# Vercel automation (optional — enables in-app Cerner/Epic credential setup on production)
# Create a token at https://vercel.com/account/tokens with access to this project.
# VERCEL_PROJECT_ID is auto-injected on Vercel deployments; set it manually for local testing.
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_TEAM_ID=
# VERCEL_PROJECT_NAME is auto-injected on Vercel when system env vars are enabled
# Optional: require this header (X-Setup-Secret) to update credentials after first setup
# SMART_SETUP_SECRET=
# SMART_SESSION_SECRET=change-me-in-production
# APP_BASE_URL=http://localhost:5173

# Optional: JSON file with { "baseUrl": "..." } used only by Docker entrypoint FHIR wait
# FHIR_CONFIG_PATH=../config/fhir.json

# Skip blocking on FHIR /metadata at container start (useful for external servers)
# FHIR_WAIT=false

# Express server
PORT=3001

# Vite client (leave empty in dev - uses Vite proxy)
VITE_API_BASE=

# Agent LLM (Journey C ask). Optional. Without a key, answers are extractive from FHIR context.
# Auto-detects a single present key. With multiple keys, set LLM_PROVIDER explicitly.
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# or GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-5
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
