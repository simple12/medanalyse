{
  "name": "fhir-patient-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client && npm run build --prefix server",
    "start": "NODE_ENV=production npm run start --prefix server",
    "docker:build": "docker compose build patient-app",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f patient-app",
    "fhir:up": "docker compose up -d db hapi-fhir",
    "fhir:down": "docker compose down",
    "seed:generate": "node scripts/generate-seed-bundle.mjs",
    "seed:clinical": "bash scripts/seed-clinical-data.sh",
    "deploy:vercel": "bash scripts/deploy-vercel.sh"
  },
  "devDependencies": {
    "@vercel/node": "^5.1.8",
    "concurrently": "^9.1.2"
  }
}
